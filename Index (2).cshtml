@model IEnumerable<Employee_Verification_System.Admin.Models.FirestoreEmployee>
@{
    ViewData["Title"] = "Employee Management";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-users"></i> Employee Management</h2>
    <div>
        <span class="badge bg-warning me-2" id="pendingBadge">
            @Model.Count(e => !e.isVerified) Pending
        </span>
        <span class="badge bg-success me-2" id="verifiedBadge">
            @Model.Count(e => e.isVerified) Verified
        </span>
        <a asp-controller="Home" asp-action="Dashboard" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Dashboard
        </a>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">All Employees</h5>
        <div>
            <button class="btn btn-outline-primary btn-sm" onclick="refreshEmployeeList()">
                <i class="fas fa-sync-alt"></i> Refresh
            </button>
        </div>
    </div>
    <div class="card-body">
        @if (!Model.Any())
        {
            <div class="alert alert-info">
                <i class="fas fa-info-circle"></i> No employees found in the system.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover" id="employeesTable">
                    <thead class="table-dark">
                        <tr>
                            <th>Employee Number</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Department</th>
                            <th>Status</th>
                            <th>Location</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var employee in Model)
                        {
                            <tr id="row-@employee.email.Replace("@", "_").Replace(".", "_")" data-verified="@employee.isVerified.ToString().ToLower()">
                                <td>@employee.employeeNumber</td>
                                <td>@employee.firstName @employee.lastName</td>
                                <td>@employee.email</td>
                                <td>@employee.department</td>
                                <td>
                                    @if (employee.isVerified)
                                    {
                                        <span class="badge bg-success verified-status">
                                            <i class="fas fa-check-circle"></i> Verified
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning verified-status">
                                            <i class="fas fa-clock"></i> Pending
                                        </span>
                                    }
                                </td>
                                <td>@employee.location</td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@employee.email" class="btn btn-sm btn-primary">
                                        <i class="fas fa-eye"></i> View
                                    </a>

                                    @if (!employee.isVerified)
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-secondary verify-btn" data-email="@employee.email" data-verified="false">
                                            <i class="fas fa-check"></i> Verify
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-sm btn-success verify-btn" data-email="@employee.email" data-verified="true" disabled>
                                            <i class="fas fa-check-double"></i> Verified
                                        </button>
                                    }

                                    <button type="button" class="btn btn-sm btn-outline-danger delete-btn" data-email="@employee.email" data-name="@employee.firstName @employee.lastName">
                                        <i class="fas fa-trash-alt"></i> Delete
                                    </button>

                                    <button type="button" class="btn btn-sm btn-outline-warning flag-btn" data-email="@employee.email">
                                        <i class="fas fa-flag"></i> Flag
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Initialize page
        document.addEventListener('DOMContentLoaded', function() {
            initializeEventListeners();
            updateCounters();
        });

        function initializeEventListeners() {
            // Verify buttons
            document.querySelectorAll('.verify-btn[data-verified="false"]').forEach(button => {
                button.addEventListener('click', function() {
                    const email = this.getAttribute('data-email');
                    verifyEmployee(email, this);
                });
            });

            // Delete buttons
            document.querySelectorAll('.delete-btn').forEach(button => {
                button.addEventListener('click', function() {
                    const email = this.getAttribute('data-email');
                    const name = this.getAttribute('data-name');
                    deleteEmployee(email, name, this);
                });
            });

            // Flag buttons
            document.querySelectorAll('.flag-btn').forEach(button => {
                button.addEventListener('click', function() {
                    const email = this.getAttribute('data-email');
                    flagEmployee(email, this);
                });
            });
        }

        function verifyEmployee(email, button) {
            if (confirm('Are you sure you want to verify this employee?')) {
                const originalText = button.innerHTML;
                const originalClass = button.className;
                
                button.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Verifying...';
                button.className = 'btn btn-sm btn-warning verify-btn';
                button.disabled = true;

                const url = '/FirestoreEmployee/Verify';
                fetch(url, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: 'id=' + encodeURIComponent(email)
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        // Update UI
                        updateEmployeeRow(email, true);
                        
                        // Update button state
                        button.innerHTML = '<i class="fas fa-check-double"></i> Verified';
                        button.className = 'btn btn-sm btn-success verify-btn';
                        button.setAttribute('data-verified', 'true');
                        button.disabled = true;

                        // Update counters
                        updateCounters();
                        
                        // Notify dashboard
                        notifyDashboard('employeeVerified');
                        
                        showAlert('Employee verified successfully!', 'success');
                    } else {
                        button.innerHTML = originalText;
                        button.className = originalClass;
                        button.disabled = false;
                        showAlert('Error: ' + data.message, 'danger');
                    }
                })
                .catch(error => {
                    button.innerHTML = originalText;
                    button.className = originalClass;
                    button.disabled = false;
                    showAlert('Error verifying employee: ' + error, 'danger');
                });
            }
        }

        function deleteEmployee(email, name, button) {
            if (confirm(`Are you sure you want to delete ${name}? This action cannot be undone and will remove the employee from the system.`)) {
                const originalText = button.innerHTML;
                button.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Deleting...';
                button.disabled = true;

                const url = '/FirestoreEmployee/Delete';
                fetch(url, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: 'id=' + encodeURIComponent(email)
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        // Remove row from table
                        const rowId = 'row-' + email.replace(/\./g, '_');
                        const row = document.getElementById(rowId);
                        if (row) {
                            row.style.backgroundColor = '#ffe6e6';
                            setTimeout(() => {
                                row.remove();
                                updateCounters();
                                notifyDashboard('employeeDeleted');
                                showAlert('Employee deleted successfully!', 'warning');
                            }, 1000);
                        }
                    } else {
                        button.innerHTML = originalText;
                        button.disabled = false;
                        showAlert('Error: ' + data.message, 'danger');
                    }
                })
                .catch(error => {
                    button.innerHTML = originalText;
                    button.disabled = false;
                    showAlert('Error deleting employee: ' + error, 'danger');
                });
            }
        }

        function flagEmployee(email, button) {
            if (confirm('Flag this employee for review?')) {
                const originalText = button.innerHTML;
                const originalClass = button.className;

                button.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Flagging...';
                button.disabled = true;

                // Call API to flag employee
                fetch('/Dashboard/UpdateFlaggedCases', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({ increment: true })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        // Update button to show flagged state
                        button.innerHTML = '<i class="fas fa-flag"></i> Flagged';
                        button.className = 'btn btn-sm btn-danger flag-btn';
                        button.setAttribute('onclick', `unflagEmployee('${email}', this)`);
                        button.disabled = false;

                        // Notify dashboard
                        notifyDashboard('employeeFlagged');

                        showAlert('Employee flagged for review!', 'warning');
                    } else {
                        button.innerHTML = originalText;
                        button.className = originalClass;
                        button.disabled = false;
                        showAlert('Error flagging employee', 'danger');
                    }
                })
                .catch(error => {
                    button.innerHTML = originalText;
                    button.className = originalClass;
                    button.disabled = false;
                    showAlert('Error flagging employee: ' + error, 'danger');
                });
            }
        }

        function unflagEmployee(email, button) {
            if (confirm('Remove flag from this employee?')) {
                const originalText = button.innerHTML;
                button.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Unflagging...';
                button.disabled = true;

                // Call API to unflag employee
                fetch('/Dashboard/UpdateFlaggedCases', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({ increment: false })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        // Update button back to original state
                        button.innerHTML = '<i class="fas fa-flag"></i> Flag';
                        button.className = 'btn btn-sm btn-outline-warning flag-btn';
                        button.setAttribute('onclick', `flagEmployee('${email}', this)`);
                        button.disabled = false;

                        // Notify dashboard
                        notifyDashboard('employeeUnflagged');

                        showAlert('Employee unflagged!', 'info');
                    } else {
                        button.innerHTML = originalText;
                        button.disabled = false;
                        showAlert('Error unflagging employee', 'danger');
                    }
                })
                .catch(error => {
                    button.innerHTML = originalText;
                    button.disabled = false;
                    showAlert('Error unflagging employee: ' + error, 'danger');
                });
            }
        }

        function updateEmployeeRow(email, isVerified) {
            const rowId = 'row-' + email.replace(/\./g, '_');
            const row = document.getElementById(rowId);
            if (row) {
                row.setAttribute('data-verified', isVerified.toString().toLowerCase());
                
                // Update status badge
                const statusCell = row.querySelector('.verified-status');
                if (isVerified) {
                    statusCell.className = 'badge bg-success verified-status';
                    statusCell.innerHTML = '<i class="fas fa-check-circle"></i> Verified';
                } else {
                    statusCell.className = 'badge bg-warning verified-status';
                    statusCell.innerHTML = '<i class="fas fa-clock"></i> Pending';
                }
            }
        }

        function updateCounters() {
            const totalRows = document.querySelectorAll('tbody tr').length;
            const verifiedRows = document.querySelectorAll('tr[data-verified="true"]').length;
            const pendingRows = document.querySelectorAll('tr[data-verified="false"]').length;

            document.getElementById('pendingBadge').textContent = pendingRows + ' Pending';
            document.getElementById('verifiedBadge').textContent = verifiedRows + ' Verified';
        }

        function refreshEmployeeList() {
            const refreshBtn = event.target;
            const originalText = refreshBtn.innerHTML;
            refreshBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
            refreshBtn.disabled = true;

            // Reload the page after a short delay
            setTimeout(() => {
                window.location.reload();
            }, 1000);
        }

        function notifyDashboard(eventType) {
            // Dispatch custom event for dashboard to listen to
            const event = new CustomEvent(eventType, {
                detail: { timestamp: new Date().toISOString() }
            });
            document.dispatchEvent(event);
            
            // Also update localStorage for cross-tab communication
            localStorage.setItem('lastAction', eventType);
            localStorage.setItem('lastActionTime', new Date().toISOString());
        }

        function showAlert(message, type) {
            const alertDiv = document.createElement('div');
            alertDiv.className = `alert alert-${type} alert-dismissible fade show mt-3`;
            alertDiv.innerHTML = `
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            `;
            document.querySelector('.card-body').prepend(alertDiv);
            
            setTimeout(() => {
                if (alertDiv.parentElement) {
                    alertDiv.remove();
                }
            }, 5000);
        }

        // Listen for storage events (cross-tab communication)
        window.addEventListener('storage', function(e) {
            if (e.key === 'lastAction') {
                const action = e.newValue;
                if (action === 'employeeVerified' || action === 'employeeDeleted') {
                    refreshEmployeeList();
                }
            }
        });
    </script>
}